# Portfolio Agent Environment Configuration
# Copy this file to .env and customize for your needs

# ===== SECURITY & PRIVACY (Safe-by-default) =====
LOCAL_ONLY=true
REDACT_PII=true
AUTO_EMAIL=false
RETENTION_DAYS=30
CONSENT_REQUIRED=true

# ===== LLM BACKENDS =====
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=us-east-1
VLLM_BASE_URL=http://localhost:8000/v1
DEFAULT_MODEL=gpt-4o-mini

# ===== EMBEDDINGS =====
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ===== VECTOR STORES =====
VECTOR_STORE=faiss
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=your-pinecone-environment-here
OPENSEARCH_URL=https://your-opensearch-cluster.com
OPENSEARCH_USERNAME=your-opensearch-username
OPENSEARCH_PASSWORD=your-opensearch-password

# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@localhost:5432/database
VECTOR_TABLE=documents

# ===== INGESTION =====
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE_MB=10

# ===== PERSONA & PROMPTS =====
PERSONA_PROMPT="You are a professional portfolio assistant. Maintain a formal, concise tone. Cite sources when providing factual claims using [[source_id]] notation."
RECRUITER_PROMPT="You are a recruiter assistant helping evaluate candidates. Provide objective, professional assessments based on available information."
ASSISTANT_PROMPT="You are a helpful personal assistant. Be friendly, efficient, and proactive."

# ===== RAG PIPELINE =====
TOP_K_RETRIEVAL=10
TOP_K_RERANK=3
SIMILARITY_THRESHOLD=0.7
INCLUDE_CITATIONS=true

# ===== MEMORY & PERSISTENCE =====
REDIS_URL=redis://localhost:6379/0
CHECKPOINT_DIR=./.agent_checkpoints
MEMORY_TTL_HOURS=24

# ===== TOOLS =====
CALENDLY_API_KEY=your-calendly-api-key-here
EMAIL_FROM=assistant@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# ===== FINE-TUNING =====
FINE_TUNE_ENABLED=false
LORA_RANK=16
LORA_ALPHA=32
TRAINING_EPOCHS=3

# ===== LOGGING & MONITORING =====
LOG_LEVEL=INFO
ENABLE_AUDIT_LOG=true
METRICS_ENABLED=false
