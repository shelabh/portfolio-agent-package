# Portfolio Agent Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== CORE SETTINGS =====
LOCAL_ONLY=true
REDACT_PII=true

# ===== API KEYS =====
OPENAI_API_KEY=your_openai_api_key_here
# AWS_BEDROCK_ACCESS_KEY_ID=your_aws_access_key_here
# AWS_BEDROCK_SECRET_ACCESS_KEY=your_aws_secret_key_here
# AWS_BEDROCK_REGION=us-east-1

# ===== DATABASE CONFIGURATION =====
DATABASE_URL=postgresql://portfolio:password@localhost:5432/portfolio_db
REDIS_URL=redis://localhost:6379

# ===== VECTOR STORE CONFIGURATION =====
VECTOR_STORE_TYPE=faiss
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_ENVIRONMENT=your_pinecone_environment_here
# OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=admin

# ===== SECURITY SETTINGS =====
ENCRYPTION_KEY=your_32_character_encryption_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ===== LOGGING & MONITORING =====
LOG_LEVEL=INFO
ENABLE_AUDIT_LOG=true
METRICS_ENABLED=false

# ===== OPTIONAL INTEGRATIONS =====
# CALENDLY_API_KEY=your_calendly_api_key_here
# EMAIL_SERVICE_API_KEY=your_email_service_api_key_here
