# portfolio-agent canonical SDK configuration
# Copy to .env when running the supported SDK/CLI/API path from source.

# Core local path
LOCAL_ONLY=true
REDACT_PII=true
LOG_LEVEL=INFO

# Embeddings
# The supported default is local Hugging Face embeddings.
EMBEDDING_PROVIDER=hf
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=16
# EMBEDDING_DEVICE=cpu
HF_USE_SENTENCE_TRANSFORMERS=true

# Optional OpenAI embeddings instead of local HF:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=your_openai_api_key_here

# Local FAISS index
FAISS_INDEX_PATH=./faiss_index
FAISS_INDEX_TYPE=flat
FAISS_METRIC=cosine

# Ingestion / retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
TOP_K_RERANK=3
SIMILARITY_THRESHOLD=0.7

# Optional API server settings
API_HOST=127.0.0.1
API_PORT=8000
ALLOWED_ORIGINS=["*"]
